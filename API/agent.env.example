# ── JARVIS API Keys ──────────────────────────────────────────────────────────
# Copy this file to API/agent.env and fill in your keys.

# Groq (FREE — fastest LLM, Llama 3.3-70B)
# Get key at: https://console.groq.com → API Keys
GROQ_API_KEY = your_groq_key_here

# Google Gemini (FREE — backup LLM)
# Get key at: https://aistudio.google.com → Get API Key
GEMINI_API_KEY = your_gemini_key_here

# OpenAI (optional — tertiary fallback)
# Get key at: https://platform.openai.com/api-keys
OPENAI_API_KEY = your_openai_key_here

# ElevenLabs TTS (optional — premium voice)
# Get key at: https://elevenlabs.io → Profile → API Keys
ELEVENLABS_API_KEY = your_elevenlabs_key_here
ELEVENLABS_VOICE_ID = your_voice_id_here

# WolframAlpha (for math/science queries)
# Get key at: https://developer.wolframalpha.com
WOLFRAM_API_KEY = your_wolfram_key_here

# Gmail (for send email feature)
EMAIL = your_email@gmail.com
EMAIL_PASSWORD = your_app_password_here
